---
import { type Props as SEOProps, SEO as AstroSEO } from 'astro-seo'

import { BASE_URL } from '@/lib/baseUrl'
import { mainMetaData } from '@/lib/metaData'

interface Props extends SEOProps {
  imageUrl?: string
  type?: 'article' | 'website' | 'profile'
  slot: 'seo'
}

const { props } = Astro

const currentPath = Astro.url.pathname || '/'
const isFrenchPage = currentPath === '/fr' || currentPath.startsWith('/fr/')

const englishPath = isFrenchPage
  ? currentPath.replace(/^\/fr(?=\/|$)/, '') || '/'
  : currentPath
const frenchPath = isFrenchPage
  ? currentPath
  : currentPath === '/'
    ? '/fr'
    : `/fr${currentPath}`

const canonicalUrl = new URL(currentPath, BASE_URL).href
const languageAlternates = [
  { hrefLang: 'fr-FR', href: new URL(frenchPath, BASE_URL).href },
  { hrefLang: 'fr', href: new URL(frenchPath, BASE_URL).href },
  { hrefLang: 'en', href: new URL(englishPath, BASE_URL).href },
  { hrefLang: 'x-default', href: new URL(englishPath, BASE_URL).href }
]

const metaData = {
  title: props.title ?? mainMetaData.title,
  description: props.description ?? mainMetaData.description,
  image: props.imageUrl ?? `${BASE_URL}/images/og_main.png`
}

const defaultProps: SEOProps = {
  title: metaData.title,
  titleDefault: metaData.title,
  description: metaData.description,
  canonical: canonicalUrl,
  languageAlternates,
  openGraph: {
    basic: {
      image: metaData.image,
      title: metaData.title,
      type: props.type ?? 'website',
      url: canonicalUrl,
      ...props.openGraph?.basic
    },
    optional: {
      siteName: mainMetaData.title,
      description: metaData.description,
      ...props.openGraph?.optional
    }
  },
  twitter: {
    title: metaData.title,
    description: metaData.description,
    creator: '@sylvaincostes',
    card: 'summary_large_image',
    image: metaData.image,
    imageAlt: metaData.title
  }
}

const combinedProps = { ...defaultProps, ...props }
---

<AstroSEO {...combinedProps} />
