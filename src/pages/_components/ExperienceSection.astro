---
import { getCollection } from 'astro:content'

import { Book } from '@icons/Book'
import { Briefcase } from '@icons/Briefcase'

import FancyLink from '@/components/FancyLink.astro'

const entries = (await getCollection('projects'))
  .filter(({ data }) => data.type === 'experience' || data.type === 'thesis')
  .sort((a, b) => b.data.year - a.data.year)
---

<section id='experience' class='mt-40 scroll-mt-16'>
  <div class='mb-12 flex items-center justify-between gap-4'>
    <div>
      <p class='mb-1 font-mono text-xs uppercase tracking-widest text-emerald-400'>
        Career
      </p>
      <h2 class='text-2xl font-medium tracking-tight sm:text-3xl'>
        Experience & Academic Work
      </h2>
    </div>
  </div>

  <div class='relative'>
    <!-- vertical timeline line -->
    <div
      class='absolute left-[11px] top-2 hidden h-[calc(100%-1.5rem)] w-px bg-zinc-800 md:block'
    >
    </div>

    <ul class='space-y-8'>
      {
        entries.map(({ id, data }) => {
          const isThesis = data.type === 'thesis'
          const Icon = isThesis ? Book : Briefcase

          return (
            <li class='group relative flex gap-6 md:gap-10'>
              <!-- dot -->
              <div class='relative z-10 mt-1 hidden shrink-0 md:block'>
                <div
                  class:list={[
                    'flex size-6 items-center justify-center rounded-full border',
                    isThesis
                      ? 'border-indigo-700/60 bg-indigo-950/80 text-indigo-400'
                      : 'border-emerald-700/60 bg-emerald-950/80 text-emerald-400'
                  ]}
                >
                  <Icon className='size-3' />
                </div>
              </div>

              <!-- card -->
              <a
                href={`/projects/${id}`}
                class:list={[
                  'flex-1 rounded-2xl border p-5 sm:p-6',
                  'transition-colors duration-200',
                  'border-zinc-800 bg-zinc-900/40 hover:border-zinc-700 hover:bg-zinc-900/70'
                ]}
              >
                <!-- header row -->
                <div class='flex flex-wrap items-start justify-between gap-3'>
                  <div>
                    <div class='flex flex-wrap items-center gap-2'>
                      {/* mobile icon */}
                      <span
                        class:list={[
                          'inline-flex size-5 items-center justify-center rounded-full border md:hidden',
                          isThesis
                            ? 'border-indigo-700/60 bg-indigo-950/80 text-indigo-400'
                            : 'border-emerald-700/60 bg-emerald-950/80 text-emerald-400'
                        ]}
                      >
                        <Icon className='size-2.5' />
                      </span>
                      <span class='font-medium'>{data.company}</span>
                    </div>
                    <p class='mt-0.5 text-sm text-slate-400'>{data.role}</p>
                  </div>
                  <span class='shrink-0 font-mono text-xs text-zinc-500'>
                    {data.period}
                  </span>
                </div>

                <!-- description -->
                <p class='mt-3 text-sm leading-relaxed text-slate-400'>
                  {data.description}
                </p>

                <!-- tags -->
                {data.tags.length > 0 && (
                  <ul class='mt-4 flex flex-wrap gap-1.5'>
                    {data.tags.map((tag: string) => (
                      <li class='rounded border border-zinc-700/60 bg-zinc-800/50 px-2 py-0.5 font-mono text-xs text-zinc-400'>
                        {tag}
                      </li>
                    ))}
                  </ul>
                )}

                <!-- read more hint -->
                <p class='mt-4 text-xs text-zinc-600 transition-colors group-hover:text-emerald-500'>
                  Read full write-up →
                </p>
              </a>
            </li>
          )
        })
      }
    </ul>
  </div>
</section>
