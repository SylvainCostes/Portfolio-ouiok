---
import { ArgoCD } from '@icons/ArgoCD'
import { Docker } from '@icons/Docker'
import { Helm } from '@icons/Helm'
import { Kubernetes } from '@icons/Kubernetes'
import { Suitcase } from '@icons/Suitcase'
import { Terraform } from '@icons/Terraform'

import Link from '@/components/Link'

import BentoBadge from '../BentoBadge'

const tags = [
  { label: 'Kubernetes / AKS', icon: Kubernetes },
  { label: 'ArgoCD', icon: ArgoCD },
  { label: 'Terraform', icon: Terraform },
  { label: 'Helm', icon: Helm },
  { label: 'Docker', icon: Docker },
]
---

<Link
  href='/projects/sgcib-payment-platform'
  class:list={[
    'relative flex h-full flex-col gap-3 overflow-hidden rounded-[inherit] px-5 pb-4 pt-4',
    'max-xs:pb-4 md:max-lg:gap-3'
  ]}
>
  <div class='space-y-5 z-10'>
    <BentoBadge
      icon={Suitcase}
      text='Featured work'
      className={{ component: 'w-fit' }}
    />
    <div class='space-y-3'>
      <p class='text-xl leading-none'>SG CIB · Payment Platform</p>
      <p class='text-sm leading-relaxed text-slate-400'>
        Kubernetes-native CI/CD pipeline on Azure Kubernetes Service at Société
        Générale CIB — zero-downtime deployments, GitOps with ArgoCD.
      </p>
    </div>
  </div>

  <div class='z-10 mt-auto flex flex-wrap gap-2'>
    {
      tags.map(({ label, icon: Icon }) => (
        <span class='flex items-center gap-1.5 rounded-full border border-zinc-700 bg-zinc-900/70 px-3 py-1 text-xs text-zinc-300'>
          <Icon className='size-3.5 shrink-0' />
          {label}
        </span>
      ))
    }
  </div>

  <!-- subtle background glow -->
  <div
    class='pointer-events-none absolute bottom-0 right-0 h-40 w-40 translate-x-10 translate-y-10 rounded-full bg-emerald-500/10 blur-3xl'
  >
  </div>
</Link>
