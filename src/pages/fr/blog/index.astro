---
import { getCollection } from 'astro:content'

import SEO from '@/components/SEO.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getCustomTransition } from '@/lib/customTransition'

import Decorator from '../../projects/_components/Decorator.astro'

const blogEntries = await getCollection('blogFr')
---

<BaseLayout>
  <SEO
    title="Blog — Sylvain Costes"
    description="Articles sur le DevOps, Platform Engineering, et les retours d'expérience terrain."
    slot='seo'
  />
  <Decorator slot='decorator' />

  <section class='mt-16 sm:mt-40'>
    <p class='mb-1 font-mono text-xs uppercase tracking-widest text-emerald-400'>Blog</p>
    <h1 class='text-2xl font-medium tracking-tight sm:text-3xl'>Articles</h1>
    <p class='mt-3 max-w-xl text-zinc-400'>
      Retours d'expérience sur le Platform Engineering, le DevOps, et les projets perso.
    </p>
  </section>

  <section class='mt-12 sm:mt-16' transition:animate={getCustomTransition(0.2)}>
    {blogEntries.map((item) => (
      <a
        href={`/fr/blog/${item.id}`}
        class='group flex gap-8 border-t border-t-zinc-900 py-10 max-md:flex-col'
      >
        <img
          src={item.data.heroImage}
          alt={item.data.title}
          class='aspect-[2] w-full rounded-lg object-cover transition-all duration-800 group-hover:scale-105 md:aspect-[1.5] md:max-w-[216px]'
        />
        <div class='flex w-full flex-col justify-between'>
          <div class='font-light'>
            <p class='text-xs text-zinc-500'>
              {new Date(item.data.pubDate).toLocaleDateString('fr-FR', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </p>
            <p class='font-display mt-3 line-clamp-2 text-lg font-semibold leading-[1.4]'>
              {item.data.title}
            </p>
            <p class='mt-2 line-clamp-2 text-zinc-400 max-md:text-sm'>
              {item.data.description}
            </p>
          </div>
          <div class='mt-4 flex flex-wrap gap-2 xs:mt-6'>
            {item.data.tags.map((tag) => (
              <span class='rounded-full border border-zinc-700 px-2.5 py-0.5 text-xs text-zinc-400'>
                {tag}
              </span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
