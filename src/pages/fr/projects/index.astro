---
import { getCollection } from 'astro:content'

import SEO from '@/components/SEO.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getCustomTransition } from '@/lib/customTransition'

import ProjectCard from '@/components/ProjectCard'
import Decorator from '../../projects/_components/Decorator.astro'

const projects = await getCollection('projectsFr')
---

<BaseLayout>
  <SEO
    title='Projets — Sylvain Costes'
    description='Projets en Platform Engineering, sécurité, et développement full-stack.'
    slot='seo'
  />
  <Decorator slot='decorator' />

  <section class='mt-16 sm:mt-40'>
    <p class='mb-1 font-mono text-xs uppercase tracking-widest text-emerald-400'>Projets</p>
    <h1 class='text-2xl font-medium tracking-tight sm:text-3xl'>Tous les projets</h1>
    <p class='mt-3 max-w-xl text-zinc-400'>
      Du Platform Engineering à la sécurité, en passant par le machine learning et le développement système.
    </p>
  </section>

  <section
    class='mt-12 grid gap-12 sm:mt-16 sm:grid-cols-2 lg:grid-cols-3'
    transition:animate={getCustomTransition(0.2)}
  >
    {projects.map(({ id, data }) => <ProjectCard slug={id} {...data} />)}
  </section>
</BaseLayout>
