---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro'
import { getCollection, render } from 'astro:content'
import readingTime from 'reading-time'

import ContentWrapper from '@/components/ContentWrapper.astro'
import ProjectLayout from '@/layouts/ProjectLayout'
import getLastUpdatedTimeByFile from '@/pages/api/_services/github/lastUpdatedFile'

interface Props extends InferGetStaticPropsType<typeof getStaticPaths> {}

export const getStaticPaths = (async () => {
  const projectEntries = await getCollection('projectsFr')

  return projectEntries.map((entry) => ({
    params: { id: entry.id },
    props: { entry }
  }))
}) satisfies GetStaticPaths

const { entry } = Astro.props
const { Content, headings } = await render(entry)

let latestCommitUrl: string | undefined
let lastUpdatedTime: string | undefined
try {
  ;({ latestCommitUrl, lastUpdatedTime } = await getLastUpdatedTimeByFile(`projects-fr/${entry.id}.mdx`))
} catch {
  // token not available at build time — skip
}

const { minutes, words } = readingTime(entry.body!)
---

<ProjectLayout
  headings={headings}
  slug={entry.id}
  readingTime={Math.ceil(minutes)}
  wordsCount={words}
  updatedDate={lastUpdatedTime ? new Date(lastUpdatedTime) : undefined}
  latestCommitUrl={latestCommitUrl}
  {...entry.data}
>
  <ContentWrapper content={Content} />
</ProjectLayout>
